---
interface Props {
  step: string;
  icon: string;
  iconBg?: string;
  title: string;
  description: string;
  delay?: number;
  variant?: 'default' | 'fallback';
}

const { step, icon, iconBg = 'rgba(0,102,255,0.1)', title, description, delay = 0, variant = 'default' } = Astro.props;
---
<div class="flow-card fade-up" style={`transition-delay: ${delay}s`} class:list={[variant === 'fallback' && 'flow-card-fallback']}>
  <div class="flow-step">{step}</div>
  <div class="flow-icon" style={`background: ${iconBg}`}>
    <i class={icon}></i>
  </div>
  <div class="flow-title">{title}</div>
  <div class="flow-desc">{description}</div>
</div>

<style>
  .flow-card {
    padding: 2.5rem 2rem;
    background: var(--white-05);
    border: 1px solid var(--white-10);
    border-radius: 20px;
    transition: all 0.35s;
  }

  .flow-card:hover {
    border-color: rgba(0, 102, 255, 0.4);
    transform: translateY(-4px);
  }

  .flow-card-fallback {
    border-color: rgba(0, 102, 255, 0.2);
    background: rgba(0, 102, 255, 0.03);
  }

  .flow-step {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--brand-blue);
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .flow-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin-bottom: 1.25rem;
  }

  .flow-icon :global(i) {
    font-size: inherit;
  }

  .flow-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .flow-desc {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.65;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
