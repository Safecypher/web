---
interface Props {
  notifTitle?: string;
  notifSub?: string;
  verifyName?: string;
  verifyRole?: string;
}
const { 
  notifTitle = 'Safe Bank is calling', 
  notifSub = 'Verify this call in your app',
  verifyName = 'Jen Bordan',
  verifyRole = 'Safe Bank · Account Services'
} = Astro.props;
---
<div class="hero-visual">
  <div class="phone-mockup">
    <div class="phone-screen">
      <div class="phone-status">
        <span>9:41</span>
        <span><i class="bi bi-lightning-charge-fill"></i> 5G</span>
      </div>
      <div class="phone-notch"></div>
      <div class="notification-card">
        <div class="notif-header">
          <div class="notif-icon"><i class="bi bi-bank2"></i></div>
          <div>
            <div class="notif-title">{notifTitle}</div>
            <div class="notif-sub">{notifSub}</div>
          </div>
        </div>
        <div class="verify-box">
          <span class="verify-shield"><i class="bi bi-shield-check"></i></span>
          <div class="verify-name">{verifyName}</div>
          <div class="verify-role">{verifyRole}</div>
          <div class="verify-badge">
            <span><i class="bi bi-check-circle-fill"></i></span> Verified Caller
          </div>
        </div>
      </div>
      <div class="phone-action">
        <span><i class="bi bi-lock-fill"></i></span> Confirm with Face ID
      </div>
      <div class="phone-faceid">
        <i class="bi bi-shield-lock-fill"></i> Secured by SafeCypher
      </div>
    </div>
  </div>
</div>

<style>
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .phone-mockup {
    width: 300px;
    background: #111;
    border-radius: 36px;
    padding: 8px;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.08);
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .phone-screen {
    background: #0a0a0a;
    border-radius: 28px;
    overflow: hidden;
  }

  .phone-status {
    padding: 14px 24px 8px;
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .phone-notch {
    width: 120px;
    height: 28px;
    background: #111;
    border-radius: 0 0 16px 16px;
    margin: 0 auto;
    position: relative;
    top: -8px;
  }

  .notification-card {
    margin: 12px 16px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(0, 102, 255, 0.3);
    border-radius: 16px;
    animation: slideIn 0.8s ease-out 0.5s both;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .notif-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .notif-icon {
    width: 40px;
    height: 40px;
    background: var(--brand-blue);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .notif-title {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
  }

  .notif-sub {
    font-size: 12px;
    color: #888;
    margin-top: 2px;
  }

  .verify-box {
    background: rgba(0, 102, 255, 0.1);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    margin-top: 12px;
  }

  .verify-shield {
    font-size: 48px;
    margin-bottom: 8px;
    display: block;
  }

  .verify-name {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }

  .verify-role {
    font-size: 13px;
    color: #888;
    margin-bottom: 16px;
  }

  .verify-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0, 200, 100, 0.15);
    color: #00c864;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
  }

  .phone-action {
    margin: 16px;
    padding: 14px;
    background: var(--brand-blue);
    border-radius: 14px;
    text-align: center;
    font-weight: 600;
    font-size: 15px;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .phone-faceid {
    text-align: center;
    padding: 12px;
    font-size: 12px;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  @media (max-width: 768px) {
    .phone-mockup {
      width: 260px;
    }
  }
</style>
