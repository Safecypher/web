---
interface CTAButton {
  href: string;
  label: string;
  primary?: boolean;
}

interface Props {
  label?: string;
  headline: string;
  buttons: CTAButton[];
}
const { label, headline, buttons } = Astro.props;
---
<section class="cta" id="contact">
  <div class="cta-glow"></div>
  <div class="cta-inner">
    {label && <div class="section-label" style="margin-bottom: 1.5rem;">{label}</div>}
    <h2 set:html={headline} />
    <div class="cta-buttons">
      {buttons.map((btn) => (
        <a href={btn.href} class={btn.primary !== false ? 'btn-primary' : 'btn-secondary'}>
          {btn.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 8rem 2rem;
    background: var(--brand-dark);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0, 102, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .cta h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 2.5rem;
  }

  .cta h2 :global(.serif) {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    color: var(--brand-blue);
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--brand-blue);
    color: #fff;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.25s;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #0055dd;
    box-shadow: 0 8px 32px rgba(0, 102, 255, 0.25);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: transparent;
    color: #ccc;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.25s;
  }

  .btn-secondary:hover {
    border-color: var(--brand-blue);
    color: #fff;
  }
</style>
