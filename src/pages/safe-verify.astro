---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PhoneMockup from '../components/PhoneMockup.astro';
import Stats from '../components/Stats.astro';
import SectionLabel from '../components/SectionLabel.astro';
import FlowCard from '../components/FlowCard.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout
  title="Safe Verify — SafeCypher"
  description="Safe Verify transforms your banking app into a secure verification channel. Bidirectional trust for inbound and outbound calls."
  navLinks={[
    { href: '#how-it-works', label: 'How It Works' },
    { href: '#benefits', label: 'Benefits' },
    { href: '#integration', label: 'Integration' },
    { href: '/#contact', label: 'Book a Demo', isCta: true },
  ]}
>
  <Hero
    title='Phishing calls erode <span class="serif">customer trust.</span>'
    accent="Restore it instantly."
    description="Safe Verify transforms your banking app into a secure verification channel. When your bank calls a customer, they know it's really you — confirmed in-app with biometric authentication. No more security questions. No more doubt."
    primaryCta={{ href: '/#contact', label: 'Book a Demo →' }}
    secondaryCta={{ href: '#how-it-works', label: 'See How It Works' }}
  >
    <PhoneMockup slot="visual" />
  </Hero>

  <Stats
    headline="Bidirectional trust."
    sub="Inbound & outbound. Verified both ways."
    detail="Eliminating vishing fraud at the source"
    stats={[
      { number: '3–5', unit: 'min', description: 'Saved per call by eliminating security questions' },
      { number: 'Zero', unit: 'data', description: 'No PII stored. Semi-stateless architecture. GDPR compliant by design.' },
      { number: '3', unit: 'layers', description: 'Of security in a single frictionless interaction' },
    ]}
  />

  <section class="how-it-works" id="how-it-works">
    <div class="how-bg-letter">V</div>
    <div class="how-inner">
      <SectionLabel text="// How It Works" />
      <div class="section-heading">
        Outbound call <span class="serif">verification flow</span>
      </div>
      <div class="section-divider"></div>
      <div class="flow-grid">
        <FlowCard
          step="Step 01"
          icon="bi bi-telephone-fill"
          iconBg="rgba(0,102,255,0.1)"
          title="Bank initiates outbound call"
          description="The agent calls the customer. Safe Verify simultaneously sends a push notification / deep link to the customer's banking app."
          delay={0}
        />
        <FlowCard
          step="Step 02"
          icon="bi bi-bell-fill"
          iconBg="rgba(0,200,100,0.1)"
          title="Customer opens app & verifies identity"
          description="Customer opens the banking app via the notification and authenticates using three layers: phone unlock, app login, and biometric (Face ID / fingerprint)."
          delay={0.1}
        />
        <FlowCard
          step="Step 03"
          icon="bi bi-shield-fill-check"
          iconBg="rgba(255,149,0,0.1)"
          title="Bank agent verified in-app"
          description="The app displays the agent's name and department — a display that can only be triggered by a call originating from the bank. Customer sees proof it's legitimate."
          delay={0.2}
        />
        <FlowCard
          step="Step 04"
          icon="bi bi-question-circle-fill"
          iconBg="rgba(0,102,255,0.1)"
          title="Active question validation"
          description="The agent sends verification questions to the app. The customer selects the correct answer on-screen — cementing bidirectional trust without speaking sensitive details aloud."
          delay={0.3}
        />
        <FlowCard
          step="Step 05"
          icon="bi bi-check-circle-fill"
          iconBg="rgba(0,200,100,0.1)"
          title="Authenticated conversation begins"
          description="Both parties are verified. The agent can serve the customer immediately — no repetitive questions, no wasted time, no opportunity for social engineering."
          delay={0.4}
        />
        <FlowCard
          step="Fallback"
          icon="bi bi-arrow-repeat"
          iconBg="rgba(255,59,48,0.1)"
          title="Graceful fallback"
          description="If the customer is unavailable or verification fails, a message is left to contact the bank directly. Security is never compromised."
          delay={0.5}
          variant="fallback"
        />
      </div>
    </div>
  </section>

  <section class="exchanges">
    <div class="exchanges-inner">
      <SectionLabel text="// The Nuclear Key Approach" />
      <div class="section-heading">
        Three key exchanges. <span class="serif">One seamless moment.</span>
      </div>
      <div class="section-divider"></div>
      <div class="exchange-grid">
        <div class="exchange-card fade-up">
          <div class="exchange-num">01</div>
          <div class="exchange-title">Customer <span class="serif">identification</span></div>
          <div class="exchange-desc">Three layers of security achieved in a single, frictionless action through the banking app.</div>
          <div class="exchange-layers">
            <div class="layer-item"><span class="layer-dot"></span> Logs into phone (biometric)</div>
            <div class="layer-item"><span class="layer-dot"></span> Logs into banking app</div>
            <div class="layer-item"><span class="layer-dot"></span> Opens Safe Verify via deep link</div>
          </div>
        </div>
        <div class="exchange-card fade-up" style="transition-delay: 0.1s;">
          <div class="exchange-num">02</div>
          <div class="exchange-title">Agent <span class="serif">identification</span></div>
          <div class="exchange-desc">Transparent to the customer but critical for trust. The in-app display can only be triggered by a legitimate call from the bank — providing protection against spoof calls.</div>
        </div>
        <div class="exchange-card fade-up" style="transition-delay: 0.2s;">
          <div class="exchange-num">03</div>
          <div class="exchange-title">Cementing <span class="serif">the trust</span></div>
          <div class="exchange-desc">A final visible in-app interaction — the question/answer validation — reinforces to the customer that they are engaging with their bank. Bidirectional trust, confirmed.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits" id="benefits">
    <div class="benefits-inner">
      <SectionLabel text="// Why Safe Verify" />
      <div class="section-heading">
        Easier for customers. <span class="serif">Impossible for fraudsters.</span>
      </div>
      <div class="section-divider"></div>
      <div class="benefits-grid">
        <div class="benefit-list">
          <div class="benefit-item fade-up">
            <div class="benefit-icon-wrap"><i class="bi bi-lightning-charge-fill"></i></div>
            <div>
              <div class="benefit-title">3–5 minutes saved per call</div>
              <div class="benefit-desc">Eliminate repetitive security questions. Agents start serving customers immediately after bidirectional verification.</div>
            </div>
          </div>
          <div class="benefit-item fade-up">
            <div class="benefit-icon-wrap"><i class="bi bi-shield-fill-check"></i></div>
            <div>
              <div class="benefit-title">Vishing protection built in</div>
              <div class="benefit-desc">Customers see verified caller identity in-app. Spoof calls that don't originate from the bank cannot trigger the verification display.</div>
            </div>
          </div>
          <div class="benefit-item fade-up">
            <div class="benefit-icon-wrap"><i class="bi bi-lock-fill"></i></div>
            <div>
              <div class="benefit-title">Zero data at rest</div>
              <div class="benefit-desc">Semi-stateless architecture with on-the-fly calculations. No PII stored. No database to breach. GDPR compliant by design.</div>
            </div>
          </div>
          <div class="benefit-item fade-up">
            <div class="benefit-icon-wrap"><i class="bi bi-arrow-repeat"></i></div>
            <div>
              <div class="benefit-title">Bidirectional verification</div>
              <div class="benefit-desc">Works for both inbound and outbound calls. Customer verifies the bank, bank verifies the customer — simultaneously.</div>
            </div>
          </div>
        </div>
        <div class="benefits-visual fade-up">
          <div class="benefits-visual-glow"></div>
          <div class="metric-row">
            <span class="metric-label">Call handling time reduction</span>
            <span class="metric-value highlight">3–5 min</span>
          </div>
          <div class="metric-row">
            <span class="metric-label">PII stored</span>
            <span class="metric-value green">None</span>
          </div>
          <div class="metric-row">
            <span class="metric-label">Security layers</span>
            <span class="metric-value">3</span>
          </div>
          <div class="metric-row">
            <span class="metric-label">Integration time</span>
            <span class="metric-value orange">Weeks</span>
          </div>
          <div class="metric-row">
            <span class="metric-label">Traditional IDV integration</span>
            <span class="metric-value" style="color:#666; text-decoration: line-through;">6–12 months</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="integration" id="integration">
    <div class="integration-inner">
      <SectionLabel text="// Integration" color="var(--brand-blue)" />
      <div class="integration-heading">
        Drop-in. <span class="serif">Not rip-and-replace.</span>
      </div>
      <p class="integration-desc">
        Safe Verify integrates with your existing IVR and contact center infrastructure. Compatible with Amazon Connect and major telephony platforms. No full auth stream required.
      </p>
      <div class="integration-tags">
        <span class="integration-tag"><i class="bi bi-phone"></i> White-label SDK</span>
        <span class="integration-tag"><i class="bi bi-cloud"></i> Amazon Connect</span>
        <span class="integration-tag"><i class="bi bi-telephone"></i> IVR Drop-in</span>
        <span class="integration-tag"><i class="bi bi-key"></i> Tokenized Phone</span>
        <span class="integration-tag"><i class="bi bi-globe2"></i> GDPR by Design</span>
        <span class="integration-tag"><i class="bi bi-shield-check"></i> CCPA Ready</span>
        <span class="integration-tag"><i class="bi bi-puzzle"></i> REST API</span>
      </div>
    </div>
  </section>

  <CTA
    label="// Get started"
    headline={"Your customers shouldn't have to guess if a call is <span class=\"serif\">really from you.</span>"}
    buttons={[
      { href: '/#contact', label: 'Book a Demo →', primary: true },
      { href: '#how-it-works', label: 'Learn More', primary: false },
    ]}
  />

  <script>
    import '../scripts/fade-up';
  </script>
</BaseLayout>

<style>
  .how-it-works {
    padding: 8rem 2rem;
    background: var(--brand-dark);
    position: relative;
    overflow: hidden;
  }

  .how-bg-letter {
    position: absolute;
    right: -5%;
    top: 50%;
    transform: translateY(-50%);
    font-size: 40rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.015);
    pointer-events: none;
    font-family: 'Playfair Display', serif;
  }

  .how-inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .section-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .section-heading .serif {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
  }

  .section-divider {
    width: 64px;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
    margin: 1.5rem 0 4rem;
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .flow-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  .exchanges {
    padding: 8rem 2rem;
    background: #080810;
  }

  .exchanges-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .exchange-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }

  .exchange-card {
    padding: 2.5rem;
    background: linear-gradient(135deg, rgba(0, 102, 255, 0.06) 0%, transparent 60%);
    border: 1px solid rgba(0, 102, 255, 0.15);
    border-radius: 20px;
    transition: all 0.35s;
  }

  .exchange-card:hover {
    border-color: rgba(0, 102, 255, 0.4);
  }

  .exchange-num {
    font-size: 4rem;
    font-weight: 800;
    color: rgba(0, 102, 255, 0.15);
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .exchange-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .exchange-title .serif {
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .exchange-desc {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.65;
  }

  .exchange-layers {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .layer-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: #aaa;
  }

  .layer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-blue);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .exchange-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 4rem auto 0;
    }
  }

  .benefits {
    padding: 8rem 2rem;
    background: var(--brand-dark);
  }

  .benefits-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-top: 4rem;
  }

  .benefit-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .benefit-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .benefit-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
    background: rgba(0, 102, 255, 0.1);
    border: 1px solid rgba(0, 102, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .benefit-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .benefit-desc {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.6;
  }

  .benefits-visual {
    background: var(--white-05);
    border: 1px solid var(--white-10);
    border-radius: 24px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .benefits-visual-glow {
    position: absolute;
    top: -30%;
    right: -30%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0, 102, 255, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--white-10);
    position: relative;
    z-index: 2;
  }

  .metric-row:last-child {
    border-bottom: none;
  }

  .metric-label {
    font-size: 0.95rem;
    color: #888;
  }

  .metric-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .metric-value.highlight {
    color: var(--brand-blue);
  }

  .metric-value.green {
    color: #00c864;
  }

  .metric-value.orange {
    color: #ff9500;
  }

  @media (max-width: 1024px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .benefits-visual {
      margin-top: 2rem;
    }
  }

  .integration {
    padding: 6rem 2rem;
    background: var(--brand-light);
    color: var(--brand-dark);
  }

  .integration-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .integration-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .integration-heading .serif {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--brand-blue);
  }

  .integration-desc {
    font-size: 1.1rem;
    color: #666;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto 3rem;
  }

  .integration-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .integration-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #fff;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-dark);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    border: 1px solid #e5e7eb;
  }
</style>
